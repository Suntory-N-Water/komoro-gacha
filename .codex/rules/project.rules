# deny (実行拒否) の設定
prefix_rule(
    pattern=["rm", "-rf"],
    decision="forbidden",
    justification="rm -rf の実行は禁止されています"
)

prefix_rule(
    pattern=["sudo"],
    decision="forbidden",
    justification="sudo は許可されていません"
)

# allow (自動許可) の設定
prefix_rule(
    pattern=["pnpm", "run"],
    decision="allow"
)

prefix_rule(
    pattern=["git", "status"],
    decision="allow"
)

prefix_rule(
    pattern=["gh"],
    decision="allow"
)

prefix_rule(
    pattern=["pnpm", "filter"],
    decision="allow"
)
