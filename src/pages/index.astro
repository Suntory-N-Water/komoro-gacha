---
import GachaApp from '../features/gacha/GachaApp';
import Layout from '../layouts/Layout.astro';
import { staticMenuCatalogRepository } from '../infrastructure/staticMenuCatalog';
import { getSelectableGachaOptions } from '../usecase/gacha';

const selectableOptions = await getSelectableGachaOptions({
  menuCatalogRepository: staticMenuCatalogRepository,
});
---

<Layout title='小諸そばガチャ'>
  <GachaApp client:load selectableOptions={selectableOptions} />
</Layout>
