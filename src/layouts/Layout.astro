---
import '../styles/global.css';

type Props = {
  readonly title?: string;
  readonly description?: string;
};

const {
  title = '小諸そばガチャ',
  description = '小諸そばのメニュー選びに迷ったとき、量と麺種別から今日の一品をランダムに決める非公式メニューガチャ。',
} = Astro.props;
const isProd = import.meta.env.PROD;
const siteUrl =
  Astro.site ?? new URL('https://komoro-gacha.suntory-n-water.com');
const canonicalUrl = new URL(Astro.url.pathname, siteUrl).toString();
const appJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: title,
  description,
  url: canonicalUrl,
  applicationCategory: 'LifestyleApplication',
  operatingSystem: 'Any',
  inLanguage: 'ja',
  isAccessibleForFree: true,
};
---

<!doctype html>
<html lang='ja'>
  <head>
    <meta charset='UTF-8' />
    <meta name='viewport' content='width=device-width, initial-scale=1.0' />
    <meta name='description' content={description} />
    <meta name='theme-color' content='#f4ead8' />
    <meta name='apple-mobile-web-app-capable' content='yes' />
    <meta name='apple-mobile-web-app-title' content='小諸ガチャ' />
    <link rel='canonical' href={canonicalUrl} />
    <link rel='manifest' href='/manifest.webmanifest' />
    <link rel='apple-touch-icon' href='/icon-192.png' />
    <link rel='icon' type='image/svg+xml' href='/favicon.svg' />
    <link rel='icon' href='/favicon.ico' />
    <meta property='og:type' content='website' />
    <meta property='og:site_name' content='小諸そばガチャ' />
    <meta property='og:title' content={title} />
    <meta property='og:description' content={description} />
    <meta property='og:url' content={canonicalUrl} />
    <meta property='og:locale' content='ja_JP' />
    <meta name='twitter:card' content='summary' />
    <meta name='twitter:title' content={title} />
    <meta name='twitter:description' content={description} />
    <meta name='generator' content={Astro.generator} />
    <title>{title}</title>
    <script
      is:inline
      type='application/ld+json'
      set:html={JSON.stringify(appJsonLd)}
    />
  </head>
  <body>
    <slot />
    <script is:inline define:vars={{ isProd }}>
      (() => {
        if (!('serviceWorker' in navigator)) {
          return;
        }

        if (isProd) {
          window.addEventListener('load', () => {
            navigator.serviceWorker.register('/sw.js');
          });
          return;
        }

        // 開発時は既存の SW を解除し、キャッシュも破棄する(スーパーリロード不要化)
        navigator.serviceWorker.getRegistrations().then((regs) => {
          for (const reg of regs) {
            reg.unregister();
          }
        });

        if (!('caches' in window)) {
          return;
        }

        caches.keys().then((keys) => {
          for (const key of keys) {
            caches.delete(key);
          }
        });
      })();
    </script>
  </body>
</html>
