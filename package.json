{
  "name": "komoro-gacha",
  "private": true,
  "type": "module",
  "version": "0.0.1",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev --host 0.0.0.0",
    "build": "astro build",
    "start": "astro preview",
    "start:worker": "pnpm run build && wrangler dev",
    "deploy": "pnpm run build && wrangler deploy",
    "astro": "astro",
    "format": "biome format --write --reporter=github . && prettier --write --log-level warn '**/*.astro'",
    "check": "biome check .",
    "check:fix": "biome check --write .",
    "lint": "biome lint .",
    "lint:ai": "set -o pipefail && biome lint . --reporter=github 2>&1 | { grep '^::' || true; }",
    "lint:fix": "biome lint --write .",
    "lint:unsafe-fix": "biome lint --write --unsafe .",
    "type-check": "astro check && tsc --noEmit",
    "type-check:ai": "astro check && tsc --noEmit --pretty false",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "ai-check": "pnpm run format && pnpm run lint:ai && pnpm run type-check:ai",
    "cf-typegen": "wrangler types",
    "knip": "knip"
  },
  "dependencies": {
    "@astrojs/react": "^5.0.7",
    "@astrojs/sitemap": "^3.7.3",
    "@types/react-dom": "^19.2.3",
    "astro": "^6.4.6",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@biomejs/biome": "^2.5.0",
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@tailwindcss/vite": "^4.3.1",
    "@tsconfig/strictest": "^2.0.8",
    "@types/react": "^19.2.17",
    "@vitest/coverage-v8": "^4.1.8",
    "knip": "^6.16.1",
    "prettier": "^3.8.4",
    "prettier-plugin-astro": "^0.14.1",
    "tailwindcss": "^4.3.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8",
    "wrangler": "^4.100.0"
  }
}
